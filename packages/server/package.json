{
  "name": "@vereinskalender/server",
  "version": "0.1.0",
  "description": "Node.js backend server with WebSocket, webhooks, and job scheduling",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --loader tsx ./src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.0",
    "express-ws": "^5.0.0",
    "ws": "^8.14.0",
    "node-cron": "^3.0.0",
    "axios": "^1.6.0",
    "@vereinskalender/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "tsx": "^4.0.0"
  }
}
